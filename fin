#include <iostream>
#include <iomanip>
#include <string>

using namespace std;

#define MAX_COLS 5

//Classe Emprunt
class Emprunt {
private:
    double capital;
    int nbMois;
    double tauxMensuel;

public:
    Emprunt(double cap, int dureeAnnees, double tauxAnnuel)
        : capital(cap),
          nbMois(dureeAnnees * 12),
          tauxMensuel((tauxAnnuel / 100.0) / 12.0) {}

    double mensualite() const {
        double facteur = 1.0;
        for (int i = 0; i < nbMois; i++)
            facteur *= (1 + tauxMensuel);

        return (capital * tauxMensuel * facteur) / (facteur - 1);
    }

    double coutTotal() const {
        return mensualite() * nbMois;
    }
};

//Classe Utilisateur
class Utilisateur {
private:
    string nom;
    string prenom;
    string banque;
    double taux;
    double capital;
    bool banquePerso;

public:
    Utilisateur() : taux(0.0), capital(0.0), banquePerso(false) {}

    void saisir() {
        cout << "Nom : ";
        cin >> nom;
        cout << "Prenom : ";
        cin >> prenom;

        cout << "Capital : ";
        cin >> capital;

        cout << "Nom de votre banque : ";
        cin >> banque;
        cout << "Taux annuel (%) : ";
        cin >> taux;

        banquePerso = true;
    }

    double getCapital() const { return capital; }
    double getTaux() const { return taux; }
    string getBanque() const { return banque; }
    bool aUneBanquePerso() const { return banquePerso; }

    void afficher() const {
        cout << "\nUtilisateur : " << prenom << " " << nom << endl;
        if (banquePerso)
            cout << "Banque personnelle : " << banque
                 << " (" << taux << "%)\n";
    }
};

//Affichage tableau
void separation(int cols) {
    cout << "+-----------------";
    for (int i = 0; i < cols; i++)
        cout << "+--------------------";
    cout << "+\n";
}

//Classe SimulationCredit 
class SimulationCredit {
private:
    string banques[MAX_COLS];
    int nbBanques;

    int durees[3] = {10, 15, 20};
    double tauxFixes[2] = {3.0, 4.0};

public:
    SimulationCredit() : nbBanques(4) {
        banques[0] = "BP";
        banques[1] = "LCL";
        banques[2] = "CA";
        banques[3] = "BNP";
    }

    void ajouterBanqueUtilisateur(const Utilisateur& user) {
        if (user.aUneBanquePerso())
            banques[nbBanques++] = user.getBanque();
    }

    void afficher(double capital, const Utilisateur& user) const {
        double meilleureMensualite = 1e12;
        string meilleureOffre;

        separation(nbBanques);
        cout << "| " << setw(15) << " ";
        for (int i = 0; i < nbBanques; i++)
            cout << "| " << setw(18) << banques[i];
        cout << "|\n";
        separation(nbBanques);

        for (int t = 0; t < 2; t++) {
            cout << "| Taux " << setw(9) << tauxFixes[t] << "% ";
            for (int i = 0; i < nbBanques; i++)
                cout << "| " << setw(18) << " ";
            cout << "|\n";
            separation(nbBanques);

            for (int d = 0; d < 3; d++) {
                cout << "| " << setw(15) << durees[d];

                for (int b = 0; b < nbBanques; b++) {
                    double taux = tauxFixes[t];

                    if (b == nbBanques - 1 && user.aUneBanquePerso())
                        taux = user.getTaux();

                    Emprunt e(capital, durees[d], taux);
                    double m = e.mensualite();

                    if (m < meilleureMensualite) {
                        meilleureMensualite = m;
                        meilleureOffre =
                            banques[b] + " / " +
                            to_string(durees[d]) + " ans / " +
                            to_string(taux) + "%";
                    }

                    cout << "| " << setw(18) << m;
                }
                cout << "|\n";
                separation(nbBanques);
            }
        }

        cout << "\n Meilleure offre detectee : " << meilleureOffre << endl;
        cout << " Mensualite minimale : " << meilleureMensualite << " €\n";
    }
};

// ================== main ==================
int main() {
    cout << fixed << setprecision(2);

    Utilisateur user;
    SimulationCredit simulation;

    double capital;
    char choix;

    cout << "Souhaitez-vous renseigner vos informations ? (o/n) : ";
    cin >> choix;

    if (choix == 'o' || choix == 'O') {
        user.saisir();
        user.afficher();
        capital = user.getCapital();
        simulation.ajouterBanqueUtilisateur(user);
    } else {
        cout << "Capital : ";
        cin >> capital;
    }

    simulation.afficher(capital, user);

    return 0;
}
